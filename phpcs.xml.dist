<?xml version="1.0"?>
<ruleset name="SymPress Maker Bundle Coding Standard">
    <config name="testVersion" value="8.5-" />
    <arg name="colors" />
    <arg value="sp" />

    <rule ref="SymPress-Plugin" />

    <file>src</file>
    <file>tests</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/var/*</exclude-pattern>
</ruleset>
